# Cloudflare Pages cache headers
# Docs: https://developers.cloudflare.com/pages/configuration/headers/

# Fonts: woff2 files realmente inmutables (URL estable + contenido estable)
/assets/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# Imágenes: cambian rara vez, cache de 30 días sin immutable
/assets/images/*
  Cache-Control: public, max-age=2592000

# CSS y JS: revalidación obligatoria en cada request
# 'no-cache' NO significa "no cachear" — significa "cachear pero revalidar con ETag antes de servir"
# Si el archivo no cambió, el server responde 304 (super eficiente y siempre actualizado)
/assets/css/*
  Cache-Control: public, no-cache

/assets/js/*
  Cache-Control: public, no-cache

# Components HTML (header, footer, modales)
/components/*
  Cache-Control: public, max-age=300, must-revalidate

# Páginas HTML: revalidar siempre
/*.html
  Cache-Control: public, no-cache

# Index / raíz
/
  Cache-Control: public, no-cache

# Headers de seguridad básicos
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: interest-cohort=()
