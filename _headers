# Cloudflare Pages cache headers
# Docs: https://developers.cloudflare.com/pages/configuration/headers/

# Fonts: woff2 files realmente inmutables (URL estable + contenido estable)
/assets/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# Imágenes: cambian rara vez, cache de 30 días sin immutable
/assets/images/*
  Cache-Control: public, max-age=2592000

# CSS y JS: revalidar SIEMPRE con ETag (no-cache). Durante desarrollo activo
# esto evita que el navegador sirva versiones viejas cacheadas. El costo es
# 1 RTT de revalidación por archivo (responde 304 si no cambió). Si el sitio
# se estabiliza, se puede volver a immutable + versionado estricto.
/assets/css/*
  Cache-Control: public, no-cache

/assets/js/*
  Cache-Control: public, no-cache

# Components HTML (header, footer, modales)
/components/*
  Cache-Control: public, max-age=300, must-revalidate

# Páginas HTML: revalidar siempre
/*.html
  Cache-Control: public, no-cache

# Index / raíz
/
  Cache-Control: public, no-cache

# Headers de seguridad básicos
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: interest-cohort=()
