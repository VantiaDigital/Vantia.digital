# Cloudflare Pages cache headers
# Docs: https://developers.cloudflare.com/pages/configuration/headers/

# Fonts: woff2 files realmente inmutables (URL estable + contenido estable)
/assets/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# Imágenes: cambian rara vez, cache de 30 días sin immutable
/assets/images/*
  Cache-Control: public, max-age=2592000

# CSS y JS: ahora con cache-bust en URL (?v=N en cada referencia desde HTML).
# Cuando se actualiza un archivo, bump del ?v en los <link>/<script> y los
# clientes reciben la versión nueva. Con immutable evitamos 1 RTT de
# revalidación ETag por archivo en cada navegación interna.
/assets/css/*
  Cache-Control: public, max-age=31536000, immutable

/assets/js/*
  Cache-Control: public, max-age=31536000, immutable

# Components HTML (header, footer, modales)
/components/*
  Cache-Control: public, max-age=300, must-revalidate

# Páginas HTML: revalidar siempre
/*.html
  Cache-Control: public, no-cache

# Index / raíz
/
  Cache-Control: public, no-cache

# Headers de seguridad básicos
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: interest-cohort=()
